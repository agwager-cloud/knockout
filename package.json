{
  "name": "knockout-classroom-game",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c green,cyan \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "client:dev": "npm run dev --workspace client",
    "client:build": "npm run build --workspace client",
    "server:dev": "npm run dev --workspace server",
    "server:start": "npm run start --workspace server",
    "zip:client": "cd client/dist && powershell Compress-Archive -Path * -DestinationPath ../../knockout-itch-client.zip -Force"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
